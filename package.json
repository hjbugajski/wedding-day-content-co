    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "payload": "3.76.1",
    "react": "^19.2.4",
    "react-day-picker": "^9.7.0",
    "react-dom": "^19.2.4",
    "resend": "^6.9.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
